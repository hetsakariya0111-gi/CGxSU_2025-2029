# Copy to .env and fill in (never commit .env).

# Atlas: Database → Connect → Drivers → SRV connection string.
# Add a database name before ? e.g. ...mongodb.net/pinatlas?retryWrites=true&w=majority
# Atlas → Network Access: allow your IP (local) or 0.0.0.0/0 (Render).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pinatlas?retryWrites=true&w=majority

PORT=5000

# Local Vite UI origin (CORS). For LAN testing, you can add comma-separated origins in server if needed.
CLIENT_URL=http://localhost:5173

# Local only. On Render set NODE_ENV=production in the dashboard.
NODE_ENV=development

# ── Render (API Web Service) — set in dashboard, not only in local .env ─────────
# NODE_ENV=production
# MONGO_URI=(same style as above)
# CLIENT_URL=https://YOUR-FRONTEND.onrender.com
# PORT is usually assigned by Render; omit PORT or leave unset on the host.
