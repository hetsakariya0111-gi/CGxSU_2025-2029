          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/query?q=meeting&category=work&isPinned=true&sortBy=title&order=asc&page=1&limit=3", "host": ["{{baseUrl}}"], "path": ["api", "notes", "query"], "query": [{"key": "q", "value": "meeting"}, {"key": "category", "value": "work"}, {"key": "isPinned", "value": "true"}, {"key": "sortBy", "value": "title"}, {"key": "order", "value": "asc"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "3"}]}
