{
  "info": {
    "name": "Notes App Assignment API",
    "description": "Complete API documentation for notes-app-assignment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. CRUD Operations",
      "item": [
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Team Standup\",\n  \"content\": \"Discuss sprint blockers and deployment plan\",\n  \"category\": \"work\",\n  \"isPinned\": true\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/notes", "host": ["{{baseUrl}}"], "path": ["api", "notes"]}
          }
        },
        {
          "name": "Create Bulk Notes",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": [\n    { \"title\": \"Note 1\", \"content\": \"Content 1\", \"category\": \"work\" },\n    { \"title\": \"Note 2\", \"content\": \"Content 2\", \"category\": \"study\" },\n    { \"title\": \"Note 3\", \"content\": \"Content 3\", \"category\": \"personal\" }\n  ]\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/notes/bulk", "host": ["{{baseUrl}}"], "path": ["api", "notes", "bulk"]}
          }
        },
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes", "host": ["{{baseUrl}}"], "path": ["api", "notes"]}
          }
        },
        {
          "name": "Get Note by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/6660f4c1b0a69a001f3a5c8d", "host": ["{{baseUrl}}"], "path": ["api", "notes", "6660f4c1b0a69a001f3a5c8d"]}
          }
        },
        {
          "name": "Replace Note (PUT)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Title\",\n  \"content\": \"New Content\",\n  \"category\": \"study\",\n  \"isPinned\": false\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/notes/6660f4c1b0a69a001f3a5c8d", "host": ["{{baseUrl}}"], "path": ["api", "notes", "6660f4c1b0a69a001f3a5c8d"]}
          }
        },
        {
          "name": "Update Note (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPinned\": true\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/notes/6660f4c1b0a69a001f3a5c8d", "host": ["{{baseUrl}}"], "path": ["api", "notes", "6660f4c1b0a69a001f3a5c8d"]}
          }
        },
        {
          "name": "Delete Single Note",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/notes/6660f4c1b0a69a001f3a5c8d", "host": ["{{baseUrl}}"], "path": ["api", "notes", "6660f4c1b0a69a001f3a5c8d"]}
          }
        },
        {
          "name": "Delete Bulk Notes",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [\"6660f4c1b0a69a001f3a5c8d\", \"6660f4c1b0a69a001f3a5c8e\"]\n}"
            },
            "url": {"raw": "{{baseUrl}}/api/notes/bulk", "host": ["{{baseUrl}}"], "path": ["api", "notes", "bulk"]}
          }
        }
      ]
    },
    {
      "name": "2. Search Operations",
      "item": [
