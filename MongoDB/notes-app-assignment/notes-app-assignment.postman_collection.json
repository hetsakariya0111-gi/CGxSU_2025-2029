        {
          "name": "Filter + Pagination",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/filter-paginate?category=work&page=1&limit=3", "host": ["{{baseUrl}}"], "path": ["api", "notes", "filter-paginate"], "query": [{"key": "category", "value": "work"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "3"}]}
          }
        },
        {
          "name": "Sort + Pagination",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/sort-paginate?sortBy=title&order=asc&page=1&limit=5", "host": ["{{baseUrl}}"], "path": ["api", "notes", "sort-paginate"], "query": [{"key": "sortBy", "value": "title"}, {"key": "order", "value": "asc"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "5"}]}
          }
        },
        {
          "name": "Search + Filter",
          "request": {
            "method": "GET",
