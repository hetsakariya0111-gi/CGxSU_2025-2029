          }
        },
        {
          "name": "Search by Content",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/search/content?q=deployment", "host": ["{{baseUrl}}"], "path": ["api", "notes", "search", "content"], "query": [{"key": "q", "value": "deployment"}]}
          }
        },
        {
          "name": "Search All Fields",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/search/all?q=react", "host": ["{{baseUrl}}"], "path": ["api", "notes", "search", "all"], "query": [{"key": "q", "value": "react"}]}
          }
        }
      ]
