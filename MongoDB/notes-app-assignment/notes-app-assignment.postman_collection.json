          }
        }
      ]
    },
    {
      "name": "4. Three Concepts Combined",
      "item": [
        {
          "name": "Search + Sort + Pagination",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/notes/search-sort-paginate?q=node&sortBy=title&order=asc&page=1&limit=5", "host": ["{{baseUrl}}"], "path": ["api", "notes", "search-sort-paginate"], "query": [{"key": "q", "value": "node"}, {"key": "sortBy", "value": "title"}, {"key": "order", "value": "asc"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "5"}]}
